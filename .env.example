# ============================================================
# Bethel Divine Healthcare Services — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or .env to version control.
# ============================================================

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service role key — bypasses RLS. Server-side ONLY. Never expose to client.
# Found in: Supabase Dashboard → Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ── Stripe ───────────────────────────────────────────────────
# Found in: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_..., sk_test_...) for development
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_publishable_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key

# Found in: Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret

# ── QuickBooks Online ─────────────────────────────────────────
# Found in: https://developer.intuit.com → My Apps → Keys & OAuth
QUICKBOOKS_CLIENT_ID=your_quickbooks_client_id
QUICKBOOKS_CLIENT_SECRET=your_quickbooks_client_secret

# Your production redirect URI — must match exactly what's registered in QB app settings
# Format: https://yourdomain.com/api/quickbooks/callback
QUICKBOOKS_REDIRECT_URI=https://betheldivine.com/api/quickbooks/callback

# ── Resend (email) ────────────────────────────────────────────
# Found in: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# The From address used in all outbound emails (must be a verified domain in Resend)
RESEND_FROM_EMAIL=noreply@betheldivine.com

# ── Web Push / VAPID ─────────────────────────────────────────
# Generate with: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix makes the public key available client-side (safe — it's public)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_EMAIL=mailto:victor@betheldivine.com

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Found in: https://console.anthropic.com/keys
# Server-side ONLY. Never prefix with NEXT_PUBLIC_.
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key

# ── EVV (Maryland Electronic Visit Verification) ──────────────
# Obtain from: Maryland Medicaid / Sandata EVV enrollment
# Leave as-is during development — EVV calls are skipped if not set
MARYLAND_EVV_API_KEY=your_evv_api_key

# ── App URL ───────────────────────────────────────────────────
# Used for building absolute URLs in emails and internal API calls
# Development: http://localhost:3000
# Production:  https://betheldivine.com
NEXT_PUBLIC_APP_URL=https://betheldivine.com
